# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Bot Invite URL (wird automatisch aus CLIENT_ID gebaut wenn leer)
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=your_discord_client_id_here

# Database (MariaDB)
DATABASE_URL="mysql://botuser:yourpassword@localhost:3306/core"
DB_ROOT_PASSWORD=sicheres_root_passwort
DB_USER=botuser
DB_PASSWORD=sicheres_bot_passwort

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
SESSION_SECRET=change_this_to_a_random_secret_string_at_least_32_chars

# Discord OAuth2 Redirect (set to your domain later)
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# Bot Settings
BOT_PORT=3001
