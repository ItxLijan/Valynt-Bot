{
  "name": "valynt-bot",
  "version": "1.0.0",
  "description": "Feature-rich Discord Bot with Web Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npx ts-node-dev --respawn --transpile-only src/index.ts\" \"npx ts-node-dev --respawn --transpile-only src/dashboard/server.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dashboard": "node dist/dashboard/server.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.15.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.11",
    "concurrently": "^8.2.2",
    "prisma": "^5.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}